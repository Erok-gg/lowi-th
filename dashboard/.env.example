# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Setup one-shot (bootstrap superadmin)
SETUP_SECRET=
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=

# Google Drive (KYC storage)
# B64 = base64 du JSON de service account
GOOGLE_SERVICE_ACCOUNT_B64=
GOOGLE_DRIVE_KYC_FOLDER_ID=

# Resend (transactional email)
RESEND_API_KEY=re_xxxxxxxxxxxx
# From address (use onboarding@resend.dev for testing — only delivers to your verified email)
RESEND_FROM=onboarding@resend.dev
# Where admin alerts are sent (new submissions, listings)
ADMIN_ALERT_EMAIL=lowi.platform@gmail.com
# Public contact for rejected submitters
SUBMISSIONS_CONTACT_EMAIL=submissions@lowi.platform.com
# Public site URL (used in email links)
NEXT_PUBLIC_SITE_URL=https://lowi-dashboard.vercel.app
# Test override : si défini, TOUS les emails transactionnels partent vers cette
# adresse au lieu du destinataire normal (pratique pour QA + contrainte test
# domain Resend qui ne livre qu'au owner). Laisser vide en prod.
TEST_EMAIL_OVERRIDE=lowi.platform@gmail.com
